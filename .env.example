# Ironman AI Chat — Configuration

# (Optional) Override the Gateway URL
# Default: http://127.0.0.1:18789
# GATEWAY_URL=http://127.0.0.1:18789

# (Optional) Override the Gateway auth token.
# If unset, the server auto-reads it from ~/.openclaw/openclaw.json
# OPENCLAW_GATEWAY_TOKEN=your_token_here

# Server port
# PORT=3456
